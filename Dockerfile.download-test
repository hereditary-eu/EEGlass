FROM node:22-bookworm AS downloader

ARG DATASET_URL="https://cloud.tugraz.at/index.php/s/q7SmjmDeJS522QP"
WORKDIR /download

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates unzip wget \
    && rm -rf /var/lib/apt/lists/*

RUN wget -O data.zip -nv "${DATASET_URL}/download" \
    || wget -O data.zip -nv "${DATASET_URL}"

RUN mkdir dataset \
    && unzip -q data.zip -d dataset \
    && test -n "$(find dataset -mindepth 1 -maxdepth 1 -type d | head -n 1)"

FROM node:22-bookworm-slim

WORKDIR /app

RUN mkdir -p /app/data/datasets

COPY --from=downloader /download/dataset/ /app/data/datasets/

CMD ["sh", "-lc", "find /app/data/datasets -maxdepth 3 -type f -print && sleep infinity"]
