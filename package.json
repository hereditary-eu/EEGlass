{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend/src/vacp/protocol/core",
    "frontend/src/vacp/protocol/diagrams",
    "frontend/src/vacp/protocol/gateway",
    "frontend/src/vacp/protocol/kit",
    "frontend/src/vacp/providers/vega-lite",
    "frontend/src/vacp/tooling/debug-ui",
    "frontend/src/vacp/transports/agent-client"
  ],
  "scripts": {
    "dev": "bun frontend/index.ts",
    "dev:hot": "bun --hot frontend/index.ts",
    "build": "bun build ./frontend/index.html --production --outdir=dist --public-path=./ --sourcemap --target=browser --minify --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun frontend/index.ts"
  },
  "dependencies": {
    "@vacp/core": "workspace:*",
    "@vacp/debug-ui": "workspace:*",
    "@vacp/diagrams": "workspace:*",
    "@vacp/gateway": "workspace:*",
    "@vacp/kit": "workspace:*",
    "@vacp/vega-lite": "workspace:*",
    "@vacp/agent-client": "workspace:*",
    "katex": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  },
  "prettier": {
    "printWidth": 120
  }
}
