{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun frontend/index.ts",
    "dev:hot": "bun --hot frontend/index.ts",
    "build": "bun build ./frontend/index.html --outdir=dist --public-path=./ --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun frontend/index.ts"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "d3": "^7.9.0",
    "katex": "^0.16.47",
    "ml-pca": "^4.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.1",
    "react-window": "1.8.11",
    "recharts": "^3.8.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "1.8.8"
  },
  "prettier": {
    "printWidth": 120
  }
}
