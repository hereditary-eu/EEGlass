{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun frontend/index.ts",
    "dev:hot": "bun --hot frontend/index.ts",
    "build": "bun build ./frontend/index.html ./frontend/clustersinfocus.html ./frontend/neurodegenvis.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun frontend/index.ts"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "d3": "^7.9.0",
    "ml-pca": "^4.1.1",
    "papaparse": "^5.5.3",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "react-table": "^7.8.0",
    "react-window": "^1.8.11",
    "recharts": "^2.15.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-table": "^7.7.20",
    "@types/react-window": "^1.8.8",
    "@types/bun": "latest"
  },
  "prettier": {
    "printWidth": 120
  }
}
