{
  "name": "@vacp/debug-ui",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*",
      "default": "./src/*"
    },
    "./style.css": "./src/style.css"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -b && tsc-alias -p tsconfig.json && pnpm run build:css",
    "build:css": "pnpm exec tailwindcss -i src/style.css -o dist/style.css",
    "dev": "pnpm run build && pnpm run dev:watch",
    "dev:watch": "pnpm exec concurrently -k -n tsc,alias,css \"pnpm run dev:tsc\" \"pnpm run dev:alias\" \"pnpm run dev:css\"",
    "dev:tsc": "tsc -b -w --preserveWatchOutput",
    "dev:alias": "tsc-alias -p tsconfig.json -w",
    "dev:css": "pnpm exec tailwindcss -i src/style.css -o dist/style.css --watch",
    "lint": "oxlint src",
    "typecheck": "tsc -b",
    "test": "pnpm exec tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.110",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@radix-ui/react-roving-focus": "^1.1.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@streamdown/code": "^1.0.3",
    "@tabler/icons-react": "^3.38.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-codemirror": "^4.25.7",
    "@vacp/agent-client": "workspace:*",
    "@vacp/core": "workspace:*",
    "@vacp/diagrams": "workspace:*",
    "apache-arrow": "^19.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-json-view-lite": "^2.5.0",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0"
  }
}
